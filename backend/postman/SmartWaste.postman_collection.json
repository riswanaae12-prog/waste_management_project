    .row { font: 14px "Segoe UI", Arial; fill: #222; }
    .cell { font: 600 16px "Segoe UI", Arial; fill: #154724; }
    .tick { fill: #1e8a3f; font: 700 20px "Segoe UI", Arial; }
    .line { stroke: #e2efe6; stroke-width: 1; }
    .headerBg { fill: #f0fbf4; }
    .box { fill: #f7fff7; stroke: #e6f3ea; stroke-width:1; rx:8; }
  </style>

  <rect width="1200" height="640" class="bg"/>
  <rect x="24" y="18" width="1152" height="76" class="headerBg" rx="10"/>
  <text x="48" y="60" class="title">Project Schedule</text>
  <text x="48" y="88" class="col">Dec — Jan — Feb — Mar (primary work / completion shown)</text>

  <rect x="40" y="110" width="1120" height="42" class="box"/>
  <text x="56" y="137" class="cell">Activity / Month</text>
  <text x="760" y="137" class="cell">Dec</text>
  <text x="840" y="137" class="cell">Jan</text>
  <text x="920" y="137" class="cell">Feb</text>
  <text x="1000" y="137" class="cell">Mar</text>

  <text x="56" y="170" class="row">Requirements & planning</text>
  <text x="760" y="170" class="tick">✓</text>

  <text x="56" y="210" class="row">Literature review & competitor analysis</text>
  <text x="760" y="210" class="tick">✓</text>

  <text x="56" y="250" class="row">System design & architecture</text>
  <text x="760" y="250" class="tick">✓</text>
  <text x="840" y="250" class="tick">✓</text>

  <text x="56" y="290" class="row">DB schema, migrations & seed data</text>
  <text x="840" y="290" class="tick">✓</text>
  <text x="920" y="290" class="tick">✓</text>

  <text x="56" y="330" class="row">Backend API (ingest, queries)</text>
  <text x="840" y="330" class="tick">✓</text>
  <text x="920" y="330" class="tick">✓</text>

  <text x="56" y="370" class="row">Simulator (device emulator)</text>
  <text x="840" y="370" class="tick">✓</text>
  <text x="920" y="370" class="tick">✓</text>

  <text x="56" y="410" class="row">Real‑time infra (Redis + WS gateway)</text>
  <text x="920" y="410" class="tick">✓</text>
  <text x="1000" y="410" class="tick">✓</text>

  <text x="56" y="450" class="row">Frontend: login, layout, widgets</text>
  <text x="840" y="450" class="tick">✓</text>

  <text x="56" y="490" class="row">Map integration (Leaflet) & Trivandrum bins</text>
  <text x="920" y="490" class="tick">✓</text>

  <text x="56" y="530" class="row">Bin / driver logic & nearest assignment</text>
  <text x="920" y="530" class="tick">✓</text>

  <text x="56" y="570" class="row">Auth / device-key enforcement</text>
  <text x="920" y="570" class="tick">✓</text>
  <text x="1000" y="570" class="tick">✓</text>

  <text x="56" y="610" class="row">Hardware implementation (sensors / gateway)</text>
  <text x="920" y="610" class="tick">✓</text>

  <rect x="560" y="240" width="600" height="200" rx="8" fill="#fbfff9" stroke="#e6f3ea"/>
  <text x="580" y="268" class="cell">Mobile Apps</text>

  <text x="580" y="300" class="row">Android — Driver application</text>
  <text x="760" y="300" class="tick">✓</text>
  <text x="840" y="300" class="tick">✓</text>

  <text x="580" y="340" class="row">Android — User application</text>
  <text x="760" y="340" class="tick">✓</text>
  <text x="840" y="340" class="tick">✓</text>

  <text x="56" y="610" class="row">Testing and analysis</text>
  <text x="1000" y="610" class="tick">✓</text>

  <text x="580" y="380" class="row">Documentation, runbook & user guide</text>
  <text x="1000" y="380" class="tick">✓</text>

  <text x="580" y="420" class="row">Final demo, stakeholder feedback & handoff</text>
