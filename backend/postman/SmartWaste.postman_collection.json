<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Download Schedule PNG</title>
  <style>body{font-family:Segoe UI,Arial,sans-serif;padding:18px;background:#fff}button{background:#1e6b37;color:#fff;border:none;padding:10px 14px;border-radius:6px;cursor:pointer}</style>
</head>
<body>
  <h3>Project Schedule — click to download PNG</h3>

  <!-- SVG (same schedule) -->
  <div id="svgContainer" style="display:none">
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="640" viewBox="0 0 1200 640">
  <style>
    .bg { fill: #ffffff; }
    .title { font: 700 28px "Segoe UI", Arial; fill: #1e6b37; }
